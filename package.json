{
  "name": "clicky-windows",
  "version": "0.1.0",
  "description": "Clicky AI companion for Windows — screen-aware AI overlay",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev:renderers": "concurrently \"vite --config vite.panel.config.ts\" \"vite --config vite.overlay.config.ts\"",
    "build": "npm run build:main && npm run build:panel && npm run build:overlay",
    "build:main": "tsc -p tsconfig.main.json",
    "build:panel": "vite build --config vite.panel.config.ts",
    "build:overlay": "vite build --config vite.overlay.config.ts",
    "electron": "electron .",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-store": "^6.0.1",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.clicky.windows",
    "productName": "Clicky",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/tray-icon.png"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "scripts/**/*",
      "pydeps/**/*"
    ]
  }
}
